{
  "name": "react-a11y-auto-caption",
  "version": "1.1.1",
  "description": "Smart React component that automatically generates alt text for images using AI.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "keywords": [
    "react",
    "accessibility",
    "a11y",
    "alt-text",
    "image-caption",
    "caption-generator",
    "screen-reader",
    "nextjs"
  ],
  "homepage": "https://github.com/kong33/react-a11y-auto-caption#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/kong33/react-a11y-auto-caption"
  },
  "bugs": {
    "url": "https://github.com/kong33/react-a11y-auto-caption/issues"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./next": {
      "import": "./dist/next.js",
      "types": "./dist/next.d.ts"
    }
  },
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --declaration --declarationDir ./dist",
    "dev": "tsup --watch"
  },
  "author": "Gaeun Kim",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "next": "^15.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "next": ">=13.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  }
}
